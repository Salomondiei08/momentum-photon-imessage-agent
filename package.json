{
  "name": "photon",
  "version": "1.0.0",
  "description": "Momentum: an iMessage-native accountability agent built with Photon",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "healthcheck": "node dist/index.js --healthcheck",
    "dry-run": "node dist/index.js --dry-run",
    "admin": "node dist/admin.js"
  },
  "keywords": [
    "photon",
    "imessage",
    "agent",
    "accountability"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@photon-ai/imessage-kit": "^2.1.2",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
